{
  "name": "budget-smuggler",
  "version": "0.0.1",
  "description": "smuggle your budget",
  "main": "index.js",
  "scripts": {
    "build": "esbuild src/index.js --bundle --outfile=src/bundle.js --sourcemap --define:global=globalThis",
    "serve": "serve src -l 9967 --no-port-switching",
    "dev": "esbuild src/index.js --bundle --outfile=src/bundle.js --sourcemap --watch --define:global=globalThis & serve src -l 9967 --no-port-switching",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krisl/BudgetSmuggler.git"
  },
  "keywords": [
    "smuggle",
    "budget"
  ],
  "author": "Aaron Lipinski <kris.lipinski@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/krisl/BudgetSmuggler/issues"
  },
  "homepage": "https://github.com/krisl/BudgetSmuggler#readme",
  "dependencies": {
    "mobx": "^2.6.0",
    "yo-yo": "^1.3.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "serve": "^14.2.6"
  }
}
